#!/bin/sh
# Wrapper to execute jellytizen
# Detects the installation directory
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
JELLYTIZEN_DIR="$SCRIPT_DIR/../share/jellytizen"
# If installed on the system
if [ ! -d "$JELLYTIZEN_DIR" ]; then
    JELLYTIZEN_DIR="/usr/share/jellytizen"
fi
# Execute main.py using system Python (not pyenv)
exec /usr/bin/python3 "$JELLYTIZEN_DIR/main.py" "$@"
